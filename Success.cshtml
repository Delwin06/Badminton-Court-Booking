@model BadmintonCourtBookingSystem.Models.Booking

@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5 text-center">

                    <div class="success-icon mb-4">

                        <i class="bi bi-check-circle-fill"></i>

                    </div>

                    <h1 class="fw-bold text-success mb-3">
                        Booking Confirmed
                    </h1>

                    <p class="text-muted mb-5">
                        Your badminton court has been booked successfully.
                    </p>

                    <div class="card border-0 bg-light rounded-4">

                        <div class="card-body p-4">

                            <div class="row text-start">

                                <div class="col-md-6 mb-3">

                                    <small class="text-muted">
                                        Booking Reference
                                    </small>

                                    <div class="fw-bold">
                                        @Model.BookingReference
                                    </div>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <small class="text-muted">
                                        Court
                                    </small>

                                    <div class="fw-bold">
                                        @Model.Court?.CourtName
                                    </div>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <small class="text-muted">
                                        Booking Date
                                    </small>

                                    <div class="fw-bold">
                                        @Model.BookingDate
                                    </div>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <small class="text-muted">
                                        Time Slot
                                    </small>

                                    <div class="fw-bold">
                                        @Model.TimeSlot?.StartTime -
                                        @Model.TimeSlot?.EndTime
                                    </div>

                                </div>

                                <div class="col-md-12">

                                    <small class="text-muted">
                                        Amount
                                    </small>

                                    <div class="fw-bold text-success fs-4">
                                        ₹@Model.Amount
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="d-flex gap-3 justify-content-center mt-5">

                        <a asp-action="Details"
                           asp-route-id="@Model.BookingId"
                           class="btn btn-outline-primary rounded-pill px-4">

                            View Booking

                        </a>

                        <a asp-action="MyBookings"
                           class="btn btn-primary rounded-pill px-4">

                            My Bookings

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .success-icon {
        font-size: 5rem;
        color: #22c55e;
    }

    .card {
        overflow: hidden;
    }

</style>