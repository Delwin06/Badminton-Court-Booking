@model BadmintonCourtBookingSystem.Models.TimeSlot

<h1>Edit Time Slot</h1>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="TimeSlotId" />

    <div class="mb-3">
        <label asp-for="StartTime"></label>
        <input asp-for="StartTime"
               type="time"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="EndTime"></label>
        <input asp-for="EndTime"
               type="time"
               class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive"
               class="form-check-input" />
        <label asp-for="IsActive"
               class="form-check-label"></label>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Update
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>