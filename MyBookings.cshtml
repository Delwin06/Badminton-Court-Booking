@model IEnumerable<BadmintonCourtBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
    var selectedStatus = ViewBag.SelectedStatus as string;
}

<div class="container py-5">

   
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

        <div>
            <h2 class="fw-bold mb-1">My Bookings</h2>
            <p class="text-muted mb-0">
                Manage all your badminton court reservations.
            </p>
        </div>

        <a asp-action="Create"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle me-2"></i>
            Book Court
        </a>

    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">

            <form method="get">

                <div class="row g-3 align-items-end">

                    <div class="col-md-4">

                        <label class="form-label fw-semibold">
                            Filter by Status
                        </label>

                        <select name="status" class="form-select">

                            <option value="" selected="@(string.IsNullOrEmpty(selectedStatus))">
                                All Bookings
                            </option>

                            <option value="Pending" selected="@(selectedStatus == "Pending")">
                                Pending
                            </option>

                            <option value="Confirmed" selected="@(selectedStatus == "Confirmed")">
                                Confirmed
                            </option>

                            <option value="Checked In" selected="@(selectedStatus == "Checked In")">
                                Checked In
                            </option>

                            <option value="Completed" selected="@(selectedStatus == "Completed")">
                                Completed
                            </option>

                            <option value="Cancelled" selected="@(selectedStatus == "Cancelled")">
                                Cancelled
                            </option>

                        </select>

                    </div>

                    <div class="col-md-2">
                        <button class="btn btn-primary w-100">
                            Filter
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">

                <i class="bi bi-calendar-x display-3 text-muted"></i>

                <h4 class="mt-3">No Bookings Found</h4>

                <p class="text-muted">
                    You haven't booked any courts yet.
                </p>

                <a asp-action="Create"
                   class="btn btn-primary rounded-pill">
                    Book Your First Court
                </a>

            </div>
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var booking in Model)
            {
                var badgeClass = booking.BookingStatus switch
                {
                    "Pending" => "bg-warning text-dark",
                    "Confirmed" => "bg-success",
                    "Checked In" => "bg-primary",
                    "Completed" => "bg-dark",
                    "Cancelled" => "bg-danger",
                    _ => "bg-secondary"
                };

                <div class="col-lg-6 mb-4">

                    <div class="card booking-card shadow-sm border-0 rounded-4 h-100">

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-start">

                                <div>

                                    <h5 class="fw-bold mb-1">
                                        @booking.Court?.CourtName
                                    </h5>

                                    <small class="text-muted">
                                        Ref: @booking.BookingReference
                                    </small>

                                </div>

                                <span class="badge @badgeClass">
                                    @booking.BookingStatus
                                </span>

                            </div>

                            <hr />

                            <div class="row">

                                <div class="col-6 mb-3">
                                    <small class="text-muted">Date</small>
                                    <div class="fw-semibold">
                                        @booking.BookingDate
                                    </div>
                                </div>

                                <div class="col-6 mb-3">
                                    <small class="text-muted">Amount</small>
                                    <div class="fw-bold text-success">
                                        ₹@booking.Amount
                                    </div>
                                </div>

                            </div>

                            <div class="mb-3">
                                <small class="text-muted">
                                    Time Slot
                                </small>

                                <div class="fw-semibold">
                                    @booking.TimeSlot?.StartTime -
                                    @booking.TimeSlot?.EndTime
                                </div>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted">
                                    Payment Status
                                </small>

                                <div class="fw-semibold">
                                    @booking.PaymentStatus
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-4">

                                <span class="text-muted">
                                    Created:
                                    @booking.CreatedAt.ToString("dd MMM yyyy")
                                </span>

                                <a asp-action="Details"
                                   asp-route-id="@booking.BookingId"
                                   class="btn btn-outline-primary rounded-pill">

                                    View Details

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    

</div>

<style>

    .booking-card {
        transition: all .3s ease;
    }

        .booking-card:hover {
            transform: translateY(-6px);
        }

    .badge {
        font-size: .85rem;
        padding: 8px 14px;
    }

</style>
